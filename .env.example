# Odysseus web interface binding
ODYSSEUS_BIND=127.0.0.1
ODYSSEUS_PORT=7000
ODYSSEUS_REF=main

# Keep auth enabled for local safety; set ODYSSEUS_ADMIN_PASSWORD to preseed.
AUTH_ENABLED=true
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=

# Ollama startup model pull
OLLAMA_MODEL=llama3.2:3b

# Odysseus provider URL for Ollama (must include /v1)
OLLAMA_BASE_URL=http://ollama:11434/v1
